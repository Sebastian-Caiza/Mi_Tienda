<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.mitienda.LoginController">
   <children>
      <VBox alignment="TOP_CENTER" maxWidth="350.0" prefHeight="380.0"
            prefWidth="350.0" spacing="12.0" StackPane.alignment="TOP_CENTER">
         <children>
            <Label text="MI TIENDA" />
            <Label text="Sistema De Ventas" />
            <Separator prefWidth="200.0" />
            <Label text="Iniciar Sesion" />
            <Label text="Usuario" />
            <TextField fx:id="ingresoUsuario" maxWidth="270.0"
                       prefHeight="25.0" prefWidth="270.0"
                       promptText="Ej: admin" />
            <Label text="Contraseña" />
            <PasswordField fx:id="ingresoPassword" maxWidth="270.0"
                           prefHeight="25.0" prefWidth="270.0" />
            <Label text="Rol" />
            <ComboBox fx:id="seleccionarRol" prefHeight="25.0"
                      prefWidth="270.0" promptText="— Seleccionar —" />
            <Button mnemonicParsing="false" onAction="#ingresoSesion"
                    prefHeight="25.0" prefWidth="270.0" text="Ingresar" />
            <Label text="admin / 1234 / Administrador" textFill="#bfb8b8" />
            <Label fx:id="lblError" textFill="RED">
               <font>
                  <Font size="13.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </children>
</StackPane>